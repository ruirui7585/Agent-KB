{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-workspace.local/schemas/prototype-agent-annotation/annotations.schema.json",
  "title": "Prototype Agent Annotations",
  "type": "object",
  "required": ["version", "annotations"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "page", "title", "description", "rules", "target", "updatedAt"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "page": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "rules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "annotationId": {
                "type": "string"
              },
              "selector": {
                "type": "string"
              }
            },
            "anyOf": [
              {
                "required": ["annotationId"]
              },
              {
                "required": ["selector"]
              }
            ]
          },
          "context": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          },
          "status": {
            "type": "string",
            "enum": ["active", "needs-review", "orphaned", "deprecated"]
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      }
    }
  }
}
