# Copy to .env on the server. Never commit real secrets.
PORT=3000
APP_TIME_ZONE=Asia/Shanghai
CALSNAP_DATA_DIR=/opt/calsnap/data

# Alibaba Cloud Model Studio (Bailian)
DASHSCOPE_API_KEY=replace-with-a-new-api-key
BAILIAN_BASE_URL=https://YOUR_WORKSPACE_ID.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
BAILIAN_PRIMARY_MODEL=qwen3.7-plus
BAILIAN_FALLBACK_MODEL=qwen3.6-flash

# Public abuse protection.
ANALYZE_RATE_LIMIT=10
ANALYZE_RATE_WINDOW_MS=600000

# Leave empty for same-origin production deployment.
ALLOWED_ORIGIN=
